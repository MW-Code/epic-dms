PORT=3000

# JWT Signing Secret — zwingend setzen, langes Random!
# Erzeugen z.B. mit:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-long-random-string

# MongoDB Verbindung — Werte muessen zu MONGO_INITDB_* unten passen
MONGO_URI=mongodb://dmsroot:bitte-aendern@localhost:27017/dms?authSource=admin

# Wird von docker-compose.yml gelesen, um Mongo-Container zu initialisieren
MONGO_INITDB_ROOT_USERNAME=dmsroot
MONGO_INITDB_ROOT_PASSWORD=bitte-aendern

# CORS Origin (Quasar Dev: 9000, Production-Build hinter nginx: Domain eintragen)
FRONTEND_ORIGIN=http://localhost:9000

# Upload-Verzeichnis (relativ zum Backend-Root oder absoluter Pfad)
UPLOAD_DIR=./uploads
