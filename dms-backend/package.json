{
  "name": "dms-backend",
  "version": "1.0.0",
  "description": "Backend fuer Epic DMS - Dokumenten-Management mit OCR-Volltextsuche",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/ocrWorker.js",
    "dev:worker": "node --watch src/workers/ocrWorker.js",
    "reocr-failed": "node scripts/reocrFailed.js",
    "migrate-paths": "node scripts/migrateStoragePaths.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Maikel Waibel",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
