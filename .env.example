# Top-Level .env fuer compose.yml
# Diese Werte werden vom Compose-Stack gelesen und an die einzelnen
# Container weitergereicht.
#
# Kopiere diese Datei zu .env und passe die Werte an:
#     cp .env.example .env

# JWT Signing Secret - lange Random-Zeichenkette.
# Erzeugen z.B. mit:
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-long-random-string

# MongoDB Root-Credentials.
# WICHTIG: keine Sonderzeichen wie ! " ^ verwenden - die machen in
# Shells und URLs Probleme. URL-safes Base64 generieren:
#     node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
MONGO_INITDB_ROOT_USERNAME=dmsroot
MONGO_INITDB_ROOT_PASSWORD=replace-me-with-strong-password

# CORS-Origin im Backend.
# Default-Compose serviert das Frontend unter http://localhost:8080.
FRONTEND_ORIGIN=http://localhost:8080

# Anzahl paralleler OCR-Worker. Tesseract ist single-threaded;
# Faustregel: 2-3 auf einer 4-8-Core-CPU.
OCR_CONCURRENCY=2
